<Window x:Class="NotesDeskClient.Win.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:NotesDeskClient.Win.Controls"
        Title="NotesDesk Client"
        Width="400" Height="540"
        MinWidth="320" MinHeight="280"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">
    <Border CornerRadius="16"
            Background="{StaticResource PanelBackground}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            Opacity="{Binding PanelOpacity}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="16,16,16,8" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Content="×" Width="22" Height="22" Margin="0,0,8,0"
                        Click="CloseButton_Click" Background="Transparent" BorderThickness="0"
                        FontSize="16" Foreground="#888" Cursor="Hand"/>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="#888" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding DisplayTitle}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="2" Content="⚙" Width="28" Height="28" Margin="4,0,4,0"
                        Click="SettingsButton_Click" Background="Transparent" BorderThickness="0" Cursor="Hand"/>
                <Ellipse Grid.Column="3" Width="8" Height="8" Margin="0,6,0,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="Orange"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ServerConnected}" Value="True">
                                    <Setter Property="Fill" Value="LimeGreen"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
            </Grid>

            <Grid Grid.Row="1" Margin="16,0,16,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="NewTaskBox" Grid.Column="0" Margin="0,0,8,0"
                         KeyDown="NewTaskBox_KeyDown"/>
                <Button Grid.Column="1" Content="添加" Click="AddTask_Click" Padding="12,4"/>
            </Grid>

            <Separator Grid.Row="2" Margin="16,0" Opacity="0.4"/>

            <ScrollViewer Grid.Row="3" Margin="16,8" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding IncompleteTasks}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <local:TaskRowControl TaskItem="{Binding}"
                                                      FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                      CompleteRequested="TaskRow_CompleteRequested"
                                                      UncompleteRequested="TaskRow_UncompleteRequested"
                                                      DueDateChanged="TaskRow_DueDateChanged"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="暂无未完成事项"
                               Visibility="{Binding HasNoIncomplete, RelativeSource={RelativeSource AncestorType=Window}}"
                               Foreground="#888" Margin="0,8"/>

                    <StackPanel Visibility="{Binding HasCompletedTasks, RelativeSource={RelativeSource AncestorType=Window}}">
                        <Grid Margin="0,12,0,4">
                            <TextBlock Text="{Binding CompletedHeader, RelativeSource={RelativeSource AncestorType=Window}}" FontWeight="SemiBold" Foreground="#888"/>
                            <Button Content="{Binding CompletedToggleLabel, RelativeSource={RelativeSource AncestorType=Window}}"
                                    HorizontalAlignment="Right" Click="ToggleCompleted_Click"
                                    Background="Transparent" BorderThickness="0" FontSize="11" Foreground="#888"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding CompletedTasks}"
                                      Visibility="{Binding ShowCompletedList, RelativeSource={RelativeSource AncestorType=Window}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <local:TaskRowControl TaskItem="{Binding}" IsCompletedMode="True"
                                                          FontSize="{Binding DataContext.FontSize, RelativeSource={RelativeSource AncestorType=Window}}"
                                                          CompleteRequested="TaskRow_CompleteRequested"
                                                          UncompleteRequested="TaskRow_UncompleteRequested"
                                                          DueDateChanged="TaskRow_DueDateChanged"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <TextBlock Text="暂无待办&#x0a;&#x0a;手机钉钉发消息到 NAS，或上方输入框添加。"
                               Visibility="{Binding ShowEmptyPlaceholder, RelativeSource={RelativeSource AncestorType=Window}}"
                               TextWrapping="Wrap" Foreground="#888" Margin="0,4"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
