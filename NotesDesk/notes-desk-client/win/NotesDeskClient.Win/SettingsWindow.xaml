<Window x:Class="NotesDeskClient.Win.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Width="440" Height="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
        <StackPanel>
            <Grid Margin="0,0,0,16">
                <TextBlock Text="设置" FontSize="16" FontWeight="SemiBold"/>
                <Button Content="完成" HorizontalAlignment="Right" Click="Close_Click" Padding="12,4"/>
            </Grid>

            <TextBlock Text="NAS 服务器" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="#888" Margin="0,0,0,12"
                       Text="连接 notes-desk-server。钉钉桥与提醒在 NAS 端运行。"/>

            <TextBlock Text="服务器地址" FontSize="11" Foreground="#888"/>
            <TextBox x:Name="ServerUrlBox" Margin="0,4,0,8"/>

            <TextBlock Text="API Token（可选）" FontSize="11" Foreground="#888"/>
            <PasswordBox x:Name="ApiTokenBox" Margin="0,4,0,8"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <Button x:Name="TestButton" Content="测试连接" Click="TestConnection_Click" Padding="12,6" Margin="0,0,8,0"/>
                <Button Content="保存" Click="Save_Click" Padding="12,6" IsDefault="True"/>
            </StackPanel>

            <TextBlock x:Name="Feedback" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,12" Visibility="Collapsed"/>

            <Separator Margin="0,4,0,16"/>
            <CheckBox Content="关闭浮窗时退出程序" IsChecked="{Binding QuitOnClosePanel}" Margin="0,0,0,12"/>

            <TextBlock Text="今日统计" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <StackPanel Margin="16,0" HorizontalAlignment="Center">
                    <TextBlock x:Name="StatPlanned" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="应做" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="16,0" HorizontalAlignment="Center">
                    <TextBlock x:Name="StatCompleted" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="已完成" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Margin="16,0" HorizontalAlignment="Center">
                    <TextBlock x:Name="StatIncomplete" FontSize="20" HorizontalAlignment="Center"/>
                    <TextBlock Text="未完成" Foreground="#888" HorizontalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>
