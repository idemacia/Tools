{
  "name": "notes-desk-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "NotesDesk IM server — SQLite, DingTalk Stream, stats & LLM analysis",
  "scripts": {
    "dev": "npm run build && node --watch dist/index.js",
    "watch": "tsc --watch",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
