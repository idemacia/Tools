/* 与抽离前 .card 样式一致，并防止 flex 压缩导致上下被裁切 */
.device-card {
  flex-shrink: 0;
  background-color: rgb(24, 32, 34);
  border-radius: 8px;
  padding: 15px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  position: relative;
  box-sizing: border-box;
}

/* socket 页面：居中、适中宽度 */
.device-card--socket {
  margin: 15px auto 15px;
  width: 60%;
  max-width: 400px;
}

/* smartled 页面：居中、适中宽度 */
.device-card--smartled {
  margin: 15px auto 15px;
  width: 60%;
  max-width: 550px;
}

/* socket 页面原始 .image-placeholder: width 100%, height 60px */
.device-card--socket .device-card__image {
  width: 100%;
  height: 60px;
  border-radius: 4px;
  overflow: hidden;
}

/* smartled 页面原始 .image-placeholder: 80x80 */
.device-card--smartled .device-card__image {
  width: 80px;
  height: 80px;
  border-radius: 8px;
  overflow: hidden;
  margin: 0 auto;
  display: block;
}

.device-card__name {
  margin-top: 10px;
  font-size: 16px;
  text-align: center;
  color: rgb(254, 254, 252);
}

.device-card__status {
  margin-top: 5px;
  margin-left: auto;
  margin-right: auto;
  font-size: 11px;
  text-align: center;
  padding: 2px 8px;
  border-radius: 10px;
  display: block;
  width: fit-content;
}

.device-card__status--connected {
  color: #4CAF50;
  background-color: rgba(76, 175, 80, 0.1);
  border: 1px solid rgba(76, 175, 80, 0.3);
}

.device-card__status--error {
  color: #F44336;
  background-color: rgba(244, 67, 54, 0.1);
  border: 1px solid rgba(244, 67, 54, 0.3);
}

.device-card__status--disconnected {
  color: #9E9E9E;
  background-color: rgba(158, 158, 158, 0.1);
  border: 1px solid rgba(158, 158, 158, 0.3);
}
