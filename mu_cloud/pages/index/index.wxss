page {
  background-color: #0F151D;
  color: #FEFEFC;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.container {
  padding: 120rpx 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: rgba(254, 254, 252, 0.95);
}

.subtitle {
  display: block;
  font-size: 28rpx;
  color: rgba(254, 254, 252, 0.6);
  padding-top: 100rpx;
  margin-bottom: 60rpx;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.device-card {
  background: rgba(24, 32, 34, 0.9);
  border-radius: 24rpx;
  padding: 48rpx;
  display: flex;
  align-items: center;
  gap: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.device-card:active {
  background: rgba(24, 32, 34, 1);
}

.device-icon {
  width: 80rpx;
  height: 80rpx;
}

.device-name {
  font-size: 34rpx;
  color: rgba(254, 254, 252, 0.9);
}
